APP_NAME=knowledge-base-system
APP_ENV=local
APP_HOST=127.0.0.1
APP_PORT=18080
APP_API_PREFIX=/api/v1
LOG_LEVEL=INFO
MAX_UPLOAD_SIZE_MB=50
APP_API_KEY=change-me
INTERNAL_TOKEN=change-me
PROVIDER_TIMEOUT_SECONDS=30
PROVIDER_RETRY_COUNT=1
HEALTH_PROBE_EXTERNAL_SERVICES=false
ALLOW_PROVIDER_FALLBACKS=true
INGESTION_MODE=sync
CORS_ALLOW_ORIGINS=http://127.0.0.1:5173,http://localhost:5173
ENABLE_FOLDER_SOURCE=false
FOLDER_SOURCE_ALLOWED_ROOTS=
ADMIN_MANUAL_USER_CREATION_ENABLED=false
ADMIN_AUTH_ENABLED=false
ADMIN_AUTH_USER_HEADERS=X-Authenticated-User,X-User-Id
ADMIN_AUTH_ALLOWED_ROLES=platform_admin
RETRIEVAL_AUTHENTICATED_IDENTITY_REQUIRED=false
AUTH_SESSION_ENABLED=false
AUTH_SESSION_SECRET=
AUTH_SESSION_TTL_SECONDS=3600
TRUSTED_IDENTITY_HEADER_ENABLED=false
TRUSTED_IDENTITY_USER_HEADERS=X-Authenticated-User,X-User-Id
TRUSTED_IDENTITY_EXTERNAL_SOURCE_HEADERS=X-Identity-Source,X-Auth-Issuer
TRUSTED_IDENTITY_EXTERNAL_ID_HEADERS=X-Identity-External-Id,X-Auth-Subject

# 权限配置
# none=无权限检查（默认），plugin=使用插件
PERMISSION_MODE=none
# 插件类路径（当 PERMISSION_MODE=plugin 时使用）
PERMISSION_PLUGIN=app.permissions.noop.NoOpPermissionChecker

DATABASE_URL=
POSTGRES_HOST=127.0.0.1
POSTGRES_PORT=5432
POSTGRES_DB=oa_rag_poc
POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres

REDIS_URL=
REDIS_HOST=127.0.0.1
REDIS_PORT=6379
REDIS_DB=0
REDIS_PASSWORD=

STORAGE_ROOT=
RAW_DATA_DIR=
PROCESSED_DATA_DIR=
SAMPLE_DATA_DIR=

ZILLIZ_URI=
ZILLIZ_TOKEN=
ZILLIZ_COLLECTION=oa_rag_chunks
VECTOR_STORE_PROVIDER=local

EMBEDDING_API_BASE=
EMBEDDING_API_KEY=
EMBEDDING_MODEL=
EMBEDDING_VECTOR_SIZE=2560

LLM_API_BASE=
LLM_API_KEY=
LLM_MODEL=
LLM_MAX_TOKENS=1200
LLM_TEMPERATURE=0.1

DIFY_BASE_URL=http://127.0.0.1:8000
DIFY_APP_KEY=
DIFY_RETRIEVAL_USER_ID=dify-external

# 图片识别配置
# 提供者类型：paddle_ocr 或 multimodal
IMAGE_RECOGNITION_PROVIDER=paddle_ocr
# PaddleOCR API Token
PADDLE_OCR_TOKEN=
# 多模态大模型配置
MULTIMODAL_API_BASE=
MULTIMODAL_API_KEY=
MULTIMODAL_MODEL=
# 图片识别超时时间（秒）
IMAGE_RECOGNITION_TIMEOUT=30
# 批量处理大小
IMAGE_RECOGNITION_BATCH_SIZE=5
