from __future__ import annotations

from sqlalchemy import select
from sqlalchemy.orm import Session

from app.core.config import get_settings
from app.core.errors import AppError, ErrorCode
from app.models.access_policy import AccessPolicy
from app.models.identity import Department, Role, UserAccount, UserRole
from app.models.identity_permission import AppRole, PermissionAuditLog, ResourcePermission, UserAppRole
from app.models.system_config import SystemConfig
from app.repositories.access_policies import AccessPolicyRepository
from app.repositories.identity import IdentityRepository
from app.repositories.identity_permission import IdentityPermissionRepository
from app.repositories.system_configs import SystemConfigRepository
from app.schemas.admin import (
    AccessPolicyCreateRequest,
    AccessPolicyMigrationItem,
    AccessPolicyMigrationRequest,
    AccessPolicyMigrationResponse,
    AccessPolicyResponse,
    AccessPolicyUpdateRequest,
    DepartmentCreateRequest,
    DepartmentResponse,
    DepartmentUpdateRequest,
    RoleCreateRequest,
    RoleResponse,
    RoleUpdateRequest,
    SystemConfigCreateRequest,
    SystemConfigResponse,
    SystemConfigUpdateRequest,
    UserCreateRequest,
    UserResponse,
    UserStatusUpdateRequest,
    UserUpdateRequest,
)
from app.schemas.pagination import PaginatedResponse


USER_STATUSES = {"active", "inactive", "deleted"}
DEPARTMENT_STATUSES = {"active", "inactive"}
ROLE_STATUSES = {"active", "inactive"}


class AdminManagementService:
    def __init__(self, session: Session) -> None:
        self.session = session
        self.settings = get_settings()
        self.system_configs = SystemConfigRepository(session)
        self.access_policies = AccessPolicyRepository(session)
        self.identity = IdentityRepository(session)
        self.identity_permissions = IdentityPermissionRepository(session)

    def list_system_configs(self, *, page: int, page_size: int, keyword: str | None = None) -> PaginatedResponse[SystemConfigResponse]:
        items, total = self.system_configs.list_configs(page=page, page_size=page_size, keyword=keyword)
        return PaginatedResponse(
            items=[SystemConfigResponse.model_validate(item) for item in items],
            total=total,
            page=page,
            page_size=page_size,
        )

    def get_system_config(self, config_id: int) -> SystemConfigResponse:
        config = self.system_configs.get_by_id(config_id)
        if config is None:
            raise AppError(code=ErrorCode.INVALID_REQUEST, message="system config not found", status_code=404)
        return SystemConfigResponse.model_validate(config)

    def create_system_config(self, request: SystemConfigCreateRequest) -> SystemConfigResponse:
        if self.system_configs.get_by_key(request.config_key):
            raise AppError(code=ErrorCode.INVALID_REQUEST, message="config key already exists", status_code=409)
        config = SystemConfig(
            config_key=request.config_key,
            config_value=request.config_value,
            description=request.description,
        )
        self.system_configs.add(config)
        self.session.commit()
        self.session.refresh(config)
        return SystemConfigResponse.model_validate(config)

    def update_system_config(self, config_id: int, request: SystemConfigUpdateRequest) -> SystemConfigResponse:
        config = self.system_configs.get_by_id(config_id)
        if config is None:
            raise AppError(code=ErrorCode.INVALID_REQUEST, message="system config not found", status_code=404)
        if request.config_value is not None:
            config.config_value = request.config_value
        if request.description is not None:
            config.description = request.description
        self.session.commit()
        self.session.refresh(config)
        return SystemConfigResponse.model_validate(config)

    def list_access_policies(
        self,
        *,
        page: int,
        page_size: int,
        resource_type: str | None = None,
        resource_id: str | None = None,
    ) -> PaginatedResponse[AccessPolicyResponse]:
        items, total = self.access_policies.list_policies(
            page=page,
            page_size=page_size,
            resource_type=resource_type,
            resource_id=resource_id,
        )
        return PaginatedResponse(
            items=[AccessPolicyResponse.model_validate(item) for item in items],
            total=total,
            page=page,
            page_size=page_size,
        )

    def get_access_policy(self, policy_id: int) -> AccessPolicyResponse:
        policy = self.access_policies.get_by_id(policy_id)
        if policy is None:
            raise AppError(code=ErrorCode.INVALID_REQUEST, message="access policy not found", status_code=404)
        return AccessPolicyResponse.model_validate(policy)

    def create_access_policy(self, request: AccessPolicyCreateRequest) -> AccessPolicyResponse:
        resource_type = self._normalize_required_text(request.resource_type, "resource_type", max_length=32)
        resource_id = self._normalize_required_text(request.resource_id, "resource_id", max_length=128)
        effect_scope = self._validate_status(request.effect_scope, {"allow", "deny"}, "effect_scope")
        role_codes = self._normalize_text_list(request.role_codes, "role_codes", max_length=64)
        dept_codes = self._normalize_text_list(request.dept_codes, "dept_codes", max_length=64)
        user_ids = self._normalize_text_list(request.user_ids, "user_ids", max_length=64)
        policy = AccessPolicy(
            resource_type=resource_type,
            resource_id=resource_id,
            effect_scope=effect_scope,
            role_codes=role_codes,
            dept_codes=dept_codes,
            user_ids=user_ids,
            extra_rules=request.extra_rules,
            created_by=request.created_by,
        )
        self.access_policies.add(policy)
        self.session.commit()
        self.session.refresh(policy)
        return AccessPolicyResponse.model_validate(policy)

    def update_access_policy(self, policy_id: int, request: AccessPolicyUpdateRequest) -> AccessPolicyResponse:
        policy = self.access_policies.get_by_id(policy_id)
        if policy is None:
            raise AppError(code=ErrorCode.INVALID_REQUEST, message="access policy not found", status_code=404)
        if request.effect_scope is not None:
            policy.effect_scope = self._validate_status(request.effect_scope, {"allow", "deny"}, "effect_scope")
        if request.role_codes is not None:
            policy.role_codes = self._normalize_text_list(request.role_codes, "role_codes", max_length=64)
        if request.dept_codes is not None:
            policy.dept_codes = self._normalize_text_list(request.dept_codes, "dept_codes", max_length=64)
        if request.user_ids is not None:
            policy.user_ids = self._normalize_text_list(request.user_ids, "user_ids", max_length=64)
        if request.extra_rules is not None:
            policy.extra_rules = request.extra_rules
        if request.created_by is not None:
            policy.created_by = request.created_by
        self.session.commit()
        self.session.refresh(policy)
        return AccessPolicyResponse.model_validate(policy)

    def delete_access_policy(self, policy_id: int) -> None:
        policy = self.access_policies.get_by_id(policy_id)
        if policy is None:
            raise AppError(code=ErrorCode.INVALID_REQUEST, message="access policy not found", status_code=404)
        self.access_policies.delete(policy)
        self.session.commit()

    def migrate_access_policies_to_resource_permissions(
        self,
        request: AccessPolicyMigrationRequest,
        *,
        actor_id: str | None = None,
    ) -> AccessPolicyMigrationResponse:
        policies = self.access_policies.list_all()
        items: list[AccessPolicyMigrationItem] = []
        created_count = 0
        skipped_count = 0
        failed_count = 0

        for policy in policies:
            for principal_type, principal_id in self._legacy_policy_principals(policy):
                resource_type = self._map_legacy_resource_type(policy.resource_type)
                effect = self._normalize_effect(policy.effect_scope)
                effective_actor_id = actor_id or request.created_by or policy.created_by or "access-policy-migration"
                try:
                    if resource_type is None:
                        raise ValueError(f"unsupported legacy resource_type: {policy.resource_type}")
                    if effect is None:
                        raise ValueError(f"unsupported legacy effect_scope: {policy.effect_scope}")
                    resource_type, resource_id = self._normalize_legacy_resource_target(resource_type, policy.resource_id)
                    self._prepare_legacy_principal(principal_type, principal_id, dry_run=request.dry_run)

                    existing = self.identity_permissions.get_matching_resource_permission(
                        resource_type=resource_type,
                        resource_id=resource_id,
                        action="search",
                        effect=effect,
                        principal_type=principal_type,
                        principal_id=principal_id,
                    )
                    if existing is not None:
                        skipped_count += 1
                        items.append(
                            AccessPolicyMigrationItem(
                                access_policy_id=policy.id,
                                resource_type=resource_type,
                                resource_id=resource_id,
                                effect=effect,
                                principal_type=principal_type,
                                principal_id=principal_id,
                                status="skipped",
                                message="matching resource permission already exists",
                                resource_permission_id=existing.id,
                                resource_permission_uuid=existing.permission_uuid,
                            )
                        )
                        continue

                    if request.dry_run:
                        items.append(
                            AccessPolicyMigrationItem(
                                access_policy_id=policy.id,
                                resource_type=resource_type,
                                resource_id=resource_id,
                                effect=effect,
                                principal_type=principal_type,
                                principal_id=principal_id,
                                status="would_create",
                            )
                        )
                        continue

                    permission = ResourcePermission(
                        resource_type=resource_type,
                        resource_id=resource_id,
                        action="search",
                        effect=effect,
                        principal_type=principal_type,
                        principal_id=principal_id,
                        condition_json={
                            "migrated_from": "access_policies",
                            "access_policy_id": policy.id,
                            "access_policy_uuid": str(policy.policy_uuid),
                            "legacy_extra_rules": policy.extra_rules or {},
                        },
                        priority=0,
                        created_by=effective_actor_id,
                    )
                    self.identity_permissions.add_resource_permission(permission)
                    self.session.flush()
                    self.identity_permissions.add_permission_audit_log(
                        PermissionAuditLog(
                            target_type="resource_permission",
                            target_id=str(permission.permission_uuid),
                            action="created",
                            actor_id=effective_actor_id,
                            before_json=None,
                            after_json=self._serialize_resource_permission(permission),
                            message=f"migrated from access policy {policy.id}",
                        )
                    )
                    created_count += 1
                    items.append(
                        AccessPolicyMigrationItem(
                            access_policy_id=policy.id,
                            resource_type=resource_type,
                            resource_id=resource_id,
                            effect=effect,
                            principal_type=principal_type,
                            principal_id=principal_id,
                            status="created",
                            resource_permission_id=permission.id,
                            resource_permission_uuid=permission.permission_uuid,
                        )
                    )
                except Exception as exc:
                    failed_count += 1
                    items.append(
                        AccessPolicyMigrationItem(
                            access_policy_id=policy.id,
                            resource_type=resource_type or str(policy.resource_type),
                            resource_id=policy.resource_id,
                            effect=effect or str(policy.effect_scope),
                            principal_type=principal_type,
                            principal_id=principal_id,
                            status="failed",
                            message=str(exc),
                        )
                    )

        if not request.dry_run:
            self.session.commit()
        return AccessPolicyMigrationResponse(
            dry_run=request.dry_run,
            total_policies=len(policies),
            created_count=created_count,
            skipped_count=skipped_count,
            failed_count=failed_count,
            items=items,
        )

    def list_departments(
        self,
        *,
        page: int,
        page_size: int,
        keyword: str | None = None,
        status: str | None = None,
    ) -> PaginatedResponse[DepartmentResponse]:
        status = self._validate_optional_status(status, DEPARTMENT_STATUSES, "department status")
        items, total = self.identity.list_departments(page=page, page_size=page_size, keyword=keyword, status=status)
        return PaginatedResponse(
            items=[DepartmentResponse.model_validate(item) for item in items],
            total=total,
            page=page,
            page_size=page_size,
        )

    def get_department(self, dept_code: str) -> DepartmentResponse:
        dept_code = self._normalize_required_text(dept_code, "dept_code", max_length=64)
        department = self.identity.get_department(dept_code)
        if department is None:
            raise AppError(code=ErrorCode.INVALID_REQUEST, message="department not found", status_code=404)
        return DepartmentResponse.model_validate(department)

    def create_department(self, request: DepartmentCreateRequest) -> DepartmentResponse:
        dept_code = self._normalize_required_text(request.dept_code, "dept_code", max_length=64)
        dept_name = self._normalize_required_text(request.dept_name, "dept_name", max_length=128)
        parent_dept_code = self._normalize_optional_text(request.parent_dept_code, "parent_dept_code", max_length=64)
        external_source = self._normalize_optional_text(request.external_source, "external_source", max_length=64)
        external_id = self._normalize_optional_text(request.external_id, "external_id", max_length=128)
        if self.identity.get_department(dept_code):
            raise AppError(code=ErrorCode.INVALID_REQUEST, message="department code already exists", status_code=409)
        if parent_dept_code and not self.identity.get_department(parent_dept_code):
            raise AppError(code=ErrorCode.INVALID_REQUEST, message="parent department not found", status_code=400)
        status = self._validate_status(request.status, DEPARTMENT_STATUSES, "department status")
        department = Department(
            dept_code=dept_code,
            dept_name=dept_name,
            parent_dept_code=parent_dept_code,
            status=status,
            external_source=external_source,
            external_id=external_id,
            extra_meta=request.extra_meta,
        )
        self.identity.add_department(department)
        self.session.commit()
        self.session.refresh(department)
        return DepartmentResponse.model_validate(department)

    def update_department(self, dept_code: str, request: DepartmentUpdateRequest) -> DepartmentResponse:
        dept_code = self._normalize_required_text(dept_code, "dept_code", max_length=64)
        department = self.identity.get_department(dept_code)
        if department is None:
            raise AppError(code=ErrorCode.INVALID_REQUEST, message="department not found", status_code=404)
        if request.parent_dept_code is not None:
            parent_dept_code = self._normalize_optional_text(request.parent_dept_code, "parent_dept_code", max_length=64)
            if parent_dept_code and not self.identity.get_department(parent_dept_code):
                raise AppError(code=ErrorCode.INVALID_REQUEST, message="parent department not found", status_code=400)
            department.parent_dept_code = parent_dept_code
        if request.dept_name is not None:
            department.dept_name = self._normalize_required_text(request.dept_name, "dept_name", max_length=128)
        if request.status is not None:
            department.status = self._validate_status(request.status, DEPARTMENT_STATUSES, "department status")
        if request.external_source is not None:
            department.external_source = self._normalize_optional_text(request.external_source, "external_source", max_length=64)
        if request.external_id is not None:
            department.external_id = self._normalize_optional_text(request.external_id, "external_id", max_length=128)
        if request.extra_meta is not None:
            department.extra_meta = request.extra_meta
        self.session.commit()
        self.session.refresh(department)
        return DepartmentResponse.model_validate(department)

    def list_roles(
        self,
        *,
        page: int,
        page_size: int,
        keyword: str | None = None,
        status: str | None = None,
    ) -> PaginatedResponse[RoleResponse]:
        status = self._validate_optional_status(status, ROLE_STATUSES, "role status")
        items, total = self.identity.list_roles(page=page, page_size=page_size, keyword=keyword, status=status)
        return PaginatedResponse(
            items=[RoleResponse.model_validate(item) for item in items],
            total=total,
            page=page,
            page_size=page_size,
        )

    def get_role(self, role_code: str) -> RoleResponse:
        role_code = self._normalize_required_text(role_code, "role_code", max_length=64)
        role = self.identity.get_role(role_code)
        if role is None:
            raise AppError(code=ErrorCode.INVALID_REQUEST, message="role not found", status_code=404)
        return RoleResponse.model_validate(role)

    def create_role(self, request: RoleCreateRequest) -> RoleResponse:
        role_code = self._normalize_required_text(request.role_code, "role_code", max_length=64)
        role_name = self._normalize_required_text(request.role_name, "role_name", max_length=128)
        external_source = self._normalize_optional_text(request.external_source, "external_source", max_length=64)
        external_id = self._normalize_optional_text(request.external_id, "external_id", max_length=128)
        if self.identity.get_role(role_code):
            raise AppError(code=ErrorCode.INVALID_REQUEST, message="role code already exists", status_code=409)
        status = self._validate_status(request.status, ROLE_STATUSES, "role status")
        role = Role(
            role_code=role_code,
            role_name=role_name,
            description=request.description,
            status=status,
            permissions=request.permissions,
            external_source=external_source,
            external_id=external_id,
            extra_meta=request.extra_meta,
        )
        self.identity.add_role(role)
        self.session.commit()
        self.session.refresh(role)
        return RoleResponse.model_validate(role)

    def update_role(self, role_code: str, request: RoleUpdateRequest) -> RoleResponse:
        role_code = self._normalize_required_text(role_code, "role_code", max_length=64)
        role = self.identity.get_role(role_code)
        if role is None:
            raise AppError(code=ErrorCode.INVALID_REQUEST, message="role not found", status_code=404)
        if request.role_name is not None:
            role.role_name = self._normalize_required_text(request.role_name, "role_name", max_length=128)
        if request.description is not None:
            role.description = request.description
        if request.status is not None:
            role.status = self._validate_status(request.status, ROLE_STATUSES, "role status")
        if request.permissions is not None:
            role.permissions = request.permissions
        if request.external_source is not None:
            role.external_source = self._normalize_optional_text(request.external_source, "external_source", max_length=64)
        if request.external_id is not None:
            role.external_id = self._normalize_optional_text(request.external_id, "external_id", max_length=128)
        if request.extra_meta is not None:
            role.extra_meta = request.extra_meta
        self.session.commit()
        self.session.refresh(role)
        return RoleResponse.model_validate(role)

    def list_users(
        self,
        *,
        page: int,
        page_size: int,
        keyword: str | None = None,
        status: str | None = None,
    ) -> PaginatedResponse[UserResponse]:
        status = self._validate_optional_status(status, USER_STATUSES, "status")
        items, total = self.identity.list_users(page=page, page_size=page_size, keyword=keyword, status=status)
        return PaginatedResponse(
            items=[self._build_user_response(item) for item in items],
            total=total,
            page=page,
            page_size=page_size,
        )

    def get_user(self, user_id: str) -> UserResponse:
        user_id = self._normalize_required_text(user_id, "user_id", max_length=64)
        user = self.identity.get_user(user_id)
        if user is None:
            raise AppError(code=ErrorCode.INVALID_REQUEST, message="user not found", status_code=404)
        return self._build_user_response(user)

    def create_user(self, request: UserCreateRequest) -> UserResponse:
        if not self.settings.admin_manual_user_creation_enabled:
            raise AppError(
                code=ErrorCode.PERMISSION_DENIED,
                message=(
                    "manual user creation is disabled; sync enterprise users through "
                    "identity sources or enable ADMIN_MANUAL_USER_CREATION_ENABLED for migration/dev usage"
                ),
                status_code=403,
            )
        user_id = self._normalize_required_text(request.user_id, "user_id", max_length=64)
        display_name = self._normalize_required_text(request.display_name, "display_name", max_length=128)
        external_source = self._normalize_optional_text(request.external_source, "external_source", max_length=64)
        external_id = self._normalize_optional_text(request.external_id, "external_id", max_length=128)
        department_codes = self._normalize_text_list(request.department_codes, "department_codes", max_length=64)
        role_codes = self._normalize_text_list(request.role_codes, "role_codes", max_length=64)
        primary_dept_code = self._normalize_optional_text(request.primary_dept_code, "primary_dept_code", max_length=64)
        if self.identity.get_user(user_id):
            raise AppError(code=ErrorCode.INVALID_REQUEST, message="user id already exists", status_code=409)
        self._ensure_user_external_identity_available(
            external_source=external_source,
            external_id=external_id,
            user_id=user_id,
        )
        status = self._validate_user_status(request.status)
        self._validate_identity_links(department_codes, role_codes, primary_dept_code)
        user = UserAccount(
            user_id=user_id,
            display_name=display_name,
            email=request.email,
            employee_no=request.employee_no,
            status=status,
            external_source=external_source,
            external_id=external_id,
            extra_meta=request.extra_meta,
            created_by=request.created_by,
        )
        self.identity.add_user(user)
        self.identity.set_user_departments(user_id, department_codes, primary_dept_code)
        self.identity.set_user_roles(user_id, role_codes)
        self.session.commit()
        self.session.refresh(user)
        return self._build_user_response(user)

    def update_user(self, user_id: str, request: UserUpdateRequest) -> UserResponse:
        user_id = self._normalize_required_text(user_id, "user_id", max_length=64)
        user = self.identity.get_user(user_id)
        if user is None:
            raise AppError(code=ErrorCode.INVALID_REQUEST, message="user not found", status_code=404)
        department_codes = (
            self._normalize_text_list(request.department_codes, "department_codes", max_length=64)
            if request.department_codes is not None
            else None
        )
        role_codes = (
            self._normalize_text_list(request.role_codes, "role_codes", max_length=64)
            if request.role_codes is not None
            else None
        )
        primary_dept_code = self._normalize_optional_text(request.primary_dept_code, "primary_dept_code", max_length=64)
        if department_codes is not None or role_codes is not None or request.primary_dept_code is not None:
            self._validate_identity_links(
                department_codes if department_codes is not None else self.identity.get_user_departments(user_id),
                role_codes if role_codes is not None else self.identity.get_user_roles(user_id),
                primary_dept_code,
            )
        if request.display_name is not None:
            user.display_name = self._normalize_required_text(request.display_name, "display_name", max_length=128)
        if request.email is not None:
            user.email = request.email
        if request.employee_no is not None:
            user.employee_no = request.employee_no
        status = self._validate_user_status(request.status) if request.status is not None else None
        if status is not None:
            user.status = status
        target_external_source = (
            self._normalize_optional_text(request.external_source, "external_source", max_length=64)
            if request.external_source is not None
            else user.external_source
        )
        target_external_id = (
            self._normalize_optional_text(request.external_id, "external_id", max_length=128)
            if request.external_id is not None
            else user.external_id
        )
        self._ensure_user_external_identity_available(
            external_source=target_external_source,
            external_id=target_external_id,
            user_id=user.user_id,
        )
        if request.external_source is not None:
            user.external_source = target_external_source
        if request.external_id is not None:
            user.external_id = target_external_id
        if request.extra_meta is not None:
            user.extra_meta = request.extra_meta
        if request.updated_by is not None:
            user.updated_by = request.updated_by
        if department_codes is not None or request.primary_dept_code is not None:
            effective_department_codes = department_codes if department_codes is not None else self.identity.get_user_departments(user_id)
            self.identity.set_user_departments(user_id, effective_department_codes, primary_dept_code)
        if role_codes is not None:
            self.identity.set_user_roles(user_id, role_codes)
        if status in {"inactive", "deleted"}:
            self._clear_user_authorization_links(user_id)
        self.session.commit()
        self.session.refresh(user)
        return self._build_user_response(user)

    def update_user_status(
        self,
        user_id: str,
        request: UserStatusUpdateRequest,
        *,
        actor_id: str | None = None,
    ) -> UserResponse:
        user_id = self._normalize_required_text(user_id, "user_id", max_length=64)
        user = self.identity.get_user(user_id)
        if user is None:
            raise AppError(code=ErrorCode.INVALID_REQUEST, message="user not found", status_code=404)
        status = self._validate_user_status(request.status)
        user.status = status
        user.updated_by = actor_id or request.updated_by
        if status in {"inactive", "deleted"}:
            self._clear_user_authorization_links(user_id)
        self.session.commit()
        self.session.refresh(user)
        return self._build_user_response(user)

    def _build_user_response(self, user: UserAccount) -> UserResponse:
        return UserResponse(
            id=user.id,
            user_uuid=user.user_uuid,
            user_id=user.user_id,
            display_name=user.display_name,
            email=user.email,
            employee_no=user.employee_no,
            status=user.status,
            department_codes=self.identity.get_user_departments(user.user_id),
            role_codes=self.identity.get_user_roles(user.user_id),
            external_source=user.external_source,
            external_id=user.external_id,
            extra_meta=user.extra_meta,
            created_by=user.created_by,
            updated_by=user.updated_by,
            created_at=user.created_at,
            updated_at=user.updated_at,
        )

    def _ensure_user_external_identity_available(
        self,
        *,
        external_source: str | None,
        external_id: str | None,
        user_id: str,
    ) -> None:
        if not external_source or not external_id:
            return
        existing = self.identity.get_user_by_external_identity_except(
            external_source=external_source,
            external_id=external_id,
            user_id=user_id,
        )
        if existing is not None:
            raise AppError(
                code=ErrorCode.INVALID_REQUEST,
                message="external identity already maps to another user",
                status_code=409,
            )

    @staticmethod
    def _legacy_policy_principals(policy: AccessPolicy) -> list[tuple[str, str]]:
        principals: list[tuple[str, str]] = []
        principals.extend(("user", item) for item in policy.user_ids or [] if str(item).strip())
        principals.extend(("department", item) for item in policy.dept_codes or [] if str(item).strip())
        principals.extend(("app_role", item) for item in policy.role_codes or [] if str(item).strip())
        if not principals:
            principals.append(("all", "*"))

        seen = set()
        normalized = []
        for principal_type, principal_id in principals:
            key = (principal_type, str(principal_id).strip())
            if key in seen:
                continue
            seen.add(key)
            normalized.append(key)
        return normalized

    @staticmethod
    def _map_legacy_resource_type(resource_type: str) -> str | None:
        normalized = str(resource_type).strip().lower()
        if normalized == "source_module":
            return "source"
        if normalized in {"global", "document", "source"}:
            return normalized
        return None

    @staticmethod
    def _normalize_legacy_resource_target(resource_type: str, resource_id: str) -> tuple[str, str]:
        normalized_resource_id = str(resource_id).strip()
        if resource_type == "global" or normalized_resource_id == "*":
            return "global", "*"
        return resource_type, normalized_resource_id

    @staticmethod
    def _normalize_effect(effect_scope: str) -> str | None:
        normalized = str(effect_scope).strip().lower()
        if normalized in {"allow", "deny"}:
            return normalized
        return None

    def _prepare_legacy_principal(self, principal_type: str, principal_id: str, *, dry_run: bool) -> None:
        if principal_type == "all":
            if principal_id != "*":
                raise ValueError("all principal must use *")
            return
        if principal_type == "user":
            user = self.identity.get_user(principal_id)
            if user is None or user.status != "active":
                raise ValueError(f"user not found or inactive: {principal_id}")
            return
        if principal_type == "department":
            department = self.identity.get_department(principal_id)
            if department is None or department.status != "active":
                raise ValueError(f"department not found or inactive: {principal_id}")
            return
        if principal_type == "app_role":
            self._ensure_app_role_from_legacy_role(principal_id, dry_run=dry_run)
            return
        raise ValueError(f"unsupported principal_type: {principal_type}")

    def _ensure_app_role_from_legacy_role(self, role_code: str, *, dry_run: bool) -> None:
        if dry_run:
            return

        legacy_role = self.identity.get_role(role_code)
        app_role = self.identity_permissions.get_app_role(role_code)
        if app_role is None:
            app_role = AppRole(
                role_code=role_code,
                role_name=legacy_role.role_name if legacy_role else role_code,
                description=legacy_role.description if legacy_role else "Migrated from legacy role",
                status=legacy_role.status if legacy_role else "active",
                permissions=legacy_role.permissions if legacy_role else [],
            )
            self.identity_permissions.add_app_role(app_role)

        user_roles = list(self.session.scalars(select(UserRole).where(UserRole.role_code == role_code)))
        for user_role in user_roles:
            if self.identity_permissions.get_user_app_role(user_role.user_id, role_code) is None:
                self.identity_permissions.add_user_app_role(
                    UserAppRole(user_id=user_role.user_id, role_code=role_code)
                )

    @staticmethod
    def _serialize_resource_permission(permission: ResourcePermission) -> dict:
        return {
            "id": permission.id,
            "permission_uuid": str(permission.permission_uuid),
            "resource_type": permission.resource_type,
            "resource_id": permission.resource_id,
            "action": permission.action,
            "effect": permission.effect,
            "principal_type": permission.principal_type,
            "principal_id": permission.principal_id,
            "condition_json": permission.condition_json,
            "priority": permission.priority,
            "created_by": permission.created_by,
        }

    def _validate_identity_links(
        self,
        department_codes: list[str],
        role_codes: list[str],
        primary_dept_code: str | None,
    ) -> None:
        for dept_code in department_codes:
            department = self.identity.get_department(dept_code)
            if department is None or department.status != "active":
                raise AppError(code=ErrorCode.INVALID_REQUEST, message=f"department not found or inactive: {dept_code}", status_code=400)
        for role_code in role_codes:
            role = self.identity.get_role(role_code)
            if role is None or role.status != "active":
                raise AppError(code=ErrorCode.INVALID_REQUEST, message=f"role not found or inactive: {role_code}", status_code=400)
        if primary_dept_code and primary_dept_code not in department_codes:
            raise AppError(code=ErrorCode.INVALID_REQUEST, message="primary department must be in department_codes", status_code=400)

    def _clear_user_authorization_links(self, user_id: str) -> None:
        self.identity.set_user_departments(user_id, [], None)
        self.identity.set_user_roles(user_id, [])
        self.identity_permissions.delete_user_memberships(user_id)
        self.identity_permissions.delete_user_app_roles(user_id)

    @staticmethod
    def _validate_user_status(status: str) -> str:
        return AdminManagementService._validate_status(status, USER_STATUSES, "status")

    @staticmethod
    def _validate_optional_status(status: str | None, allowed: set[str], field_name: str) -> str | None:
        if status is None:
            return None
        return AdminManagementService._validate_status(status, allowed, field_name)

    @classmethod
    def _normalize_text_list(cls, values: list[str], field_name: str, *, max_length: int) -> list[str]:
        seen: set[str] = set()
        normalized_values: list[str] = []
        for value in values:
            normalized = cls._normalize_required_text(value, field_name, max_length=max_length)
            if normalized in seen:
                continue
            seen.add(normalized)
            normalized_values.append(normalized)
        return normalized_values

    @staticmethod
    def _normalize_required_text(value: object, field_name: str, *, max_length: int) -> str:
        normalized = str(value).strip() if value is not None else ""
        if not normalized:
            raise AppError(
                code=ErrorCode.INVALID_REQUEST,
                message=f"{field_name} is required",
                status_code=400,
            )
        if len(normalized) > max_length:
            raise AppError(
                code=ErrorCode.INVALID_REQUEST,
                message=f"{field_name} must be at most {max_length} characters",
                status_code=400,
            )
        return normalized

    @classmethod
    def _normalize_optional_text(cls, value: object, field_name: str, *, max_length: int) -> str | None:
        if value is None:
            return None
        return cls._normalize_required_text(value, field_name, max_length=max_length)

    @staticmethod
    def _validate_status(status: str, allowed: set[str], field_name: str) -> str:
        normalized = status.strip().lower()
        if normalized not in allowed:
            raise AppError(
                code=ErrorCode.INVALID_REQUEST,
                message=f"{field_name} must be one of: {', '.join(sorted(allowed))}",
                status_code=400,
            )
        return normalized
